<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Échos — Retrouver ceux qui sont partis</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,300;0,400;0,700;1,300;1,400&family=EB+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Montserrat:wght@200;300;400&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:        #07070d;
  --bg2:       #0d0d16;
  --gold:      #c8a96d;
  --gold2:     #e8d5a3;
  --gold-dim:  rgba(200,169,109,0.12);
  --gold-glow: rgba(200,169,109,0.06);
  --text:      #ede7d9;
  --text-mid:  rgba(237,231,217,0.6);
  --text-dim:  rgba(237,231,217,0.35);
  --border:    rgba(200,169,109,0.15);
}

html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'EB Garamond', serif;
  font-size: 18px;
  line-height: 1.7;
  overflow-x: hidden;
  overflow-y: auto;
  cursor: none;
}

/* ══════════════ CUSTOM CURSOR ══════════════ */
#cursor {
  position: fixed;
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--gold);
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%, -50%);
  transition: width 0.2s, height 0.2s, opacity 0.2s;
  mix-blend-mode: screen;
}
#cursor-ring {
  position: fixed;
  width: 32px; height: 32px;
  border-radius: 50%;
  border: 1px solid rgba(200,169,109,0.5);
  pointer-events: none;
  z-index: 9998;
  transform: translate(-50%, -50%);
  transition: width 0.35s ease, height 0.35s ease, transform 0.1s linear;
}

/* ══════════════ CANVAS PARTICLES ══════════════ */
#canvas {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

/* ══════════════ NAV ══════════════ */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.4rem 3rem;
  backdrop-filter: blur(20px);
  background: rgba(7,7,13,0.7);
  border-bottom: 1px solid rgba(200,169,109,0.08);
}
.nav-logo {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem;
  font-weight: 300;
  letter-spacing: 0.2em;
  color: var(--gold);
}
.nav-links {
  display: flex;
  gap: 2.5rem;
  list-style: none;
}
.nav-links a {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.65rem;
  font-weight: 300;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--text-mid);
  text-decoration: none;
  transition: color 0.3s;
}
.nav-links a:hover { color: var(--gold); }
.nav-cta {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.62rem;
  font-weight: 300;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--gold);
  border: 1px solid var(--border);
  padding: 0.5rem 1.2rem;
  text-decoration: none;
  transition: all 0.3s;
  border-radius: 1px;
}
.nav-cta:hover { background: var(--gold-dim); }

/* ══════════════ HERO ══════════════ */
#hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 8rem 2rem 4rem;
  z-index: 1;
}

.hero-bg-gradient {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 50% at 50% -10%, rgba(200,169,109,0.07) 0%, transparent 60%),
    radial-gradient(ellipse 40% 60% at 20% 80%, rgba(80,40,120,0.06) 0%, transparent 50%),
    radial-gradient(ellipse 40% 40% at 80% 90%, rgba(200,169,109,0.04) 0%, transparent 50%);
  pointer-events: none;
}

.hero-eyebrow {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.6rem;
  font-weight: 300;
  letter-spacing: 0.5em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 2rem;
  opacity: 0;
  animation: riseIn 1s ease 0.3s forwards;
}

.hero-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(3.5rem, 9vw, 8rem);
  font-weight: 300;
  line-height: 1.05;
  letter-spacing: -0.01em;
  color: var(--text);
  margin-bottom: 0.3em;
  opacity: 0;
  animation: riseIn 1.2s ease 0.5s forwards;
}
.hero-title em {
  font-style: italic;
  color: var(--gold);
}

.hero-subtitle {
  font-family: 'EB Garamond', serif;
  font-size: clamp(1rem, 2.5vw, 1.35rem);
  font-style: italic;
  font-weight: 300;
  color: var(--text-mid);
  max-width: 520px;
  margin: 0 auto 3rem;
  opacity: 0;
  animation: riseIn 1.2s ease 0.8s forwards;
}

.hero-divider {
  width: 80px; height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  margin: 0 auto 2.5rem;
  opacity: 0;
  animation: riseIn 1s ease 1s forwards;
}

/* Waitlist form */
.waitlist-form {
  display: flex;
  gap: 0;
  max-width: 460px;
  width: 100%;
  margin: 0 auto 1rem;
  opacity: 0;
  animation: riseIn 1s ease 1.1s forwards;
}
.waitlist-input {
  flex: 1;
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  border-right: none;
  color: var(--text);
  font-family: 'EB Garamond', serif;
  font-size: 1rem;
  padding: 0.8rem 1.2rem;
  outline: none;
  border-radius: 1px 0 0 1px;
  transition: border-color 0.3s, background 0.3s;
}
.waitlist-input:focus {
  border-color: rgba(200,169,109,0.4);
  background: rgba(200,169,109,0.04);
}
.waitlist-input::placeholder { color: var(--text-dim); font-style: italic; }
.waitlist-btn {
  background: var(--gold);
  border: none;
  color: #07070d;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.62rem;
  font-weight: 400;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  padding: 0.8rem 1.6rem;
  cursor: none;
  border-radius: 0 1px 1px 0;
  transition: background 0.3s, transform 0.15s;
  white-space: nowrap;
}
.waitlist-btn:hover { background: var(--gold2); }
.waitlist-btn:active { transform: scale(0.98); }

.waitlist-note {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.6rem;
  font-weight: 300;
  letter-spacing: 0.1em;
  color: var(--text-dim);
  opacity: 0;
  animation: riseIn 0.8s ease 1.3s forwards;
}
#success-msg {
  display: none;
  font-family: 'EB Garamond', serif;
  font-style: italic;
  color: var(--gold);
  font-size: 1rem;
  margin-top: 0.5rem;
  animation: riseIn 0.6s ease forwards;
}

/* Scroll cue */
.scroll-cue {
  position: absolute;
  bottom: 2.5rem; left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column;
  align-items: center; gap: 0.5rem;
  opacity: 0;
  animation: riseIn 1s ease 1.8s forwards;
}
.scroll-cue span {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.55rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--text-dim);
}
.scroll-line {
  width: 1px; height: 40px;
  background: linear-gradient(to bottom, var(--gold), transparent);
  animation: scrollDrop 2s ease-in-out infinite 2s;
}
@keyframes scrollDrop {
  0%,100% { transform: scaleY(1); transform-origin: top; }
  50%      { transform: scaleY(0.3); transform-origin: top; }
}

/* ══════════════ STATS BAND ══════════════ */
#stats {
  position: relative; z-index: 1;
  background: rgba(200,169,109,0.04);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 2.5rem 3rem;
  display: flex;
  justify-content: center;
  gap: clamp(2rem, 8vw, 8rem);
  flex-wrap: wrap;
}
.stat-item { text-align: center; }
.stat-num {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 300;
  color: var(--gold);
  display: block;
  line-height: 1;
}
.stat-label {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.58rem;
  font-weight: 300;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-top: 0.4rem;
  display: block;
}

/* ══════════════ SECTION BASE ══════════════ */
section {
  position: relative;
  z-index: 1;
  padding: clamp(4rem, 10vw, 8rem) clamp(1.5rem, 5vw, 5rem);
}
.section-label {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.58rem;
  font-weight: 300;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.2rem;
  display: block;
}
.section-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 300;
  line-height: 1.2;
  margin-bottom: 1.5rem;
}
.section-title em { font-style: italic; color: var(--gold); }

/* ══════════════ HOW IT WORKS ══════════════ */
#how {
  max-width: 1100px;
  margin: 0 auto;
}
.how-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
}
.how-text { }
.how-text p {
  color: var(--text-mid);
  font-size: 1.05rem;
  margin-bottom: 1.5rem;
  font-style: italic;
}
.steps {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  margin-top: 3rem;
}
.step {
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
  opacity: 0;
  transform: translateX(-20px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.step.visible { opacity: 1; transform: translateX(0); }
.step-num {
  font-family: 'Playfair Display', serif;
  font-size: 2.5rem;
  font-weight: 300;
  color: rgba(200,169,109,0.2);
  line-height: 1;
  flex-shrink: 0;
  width: 40px;
  text-align: right;
}
.step-content h4 {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  font-weight: 400;
  margin-bottom: 0.3rem;
  color: var(--text);
}
.step-content p {
  font-size: 0.9rem;
  color: var(--text-dim);
  font-style: normal;
  margin: 0;
}

/* Phone mockup */
.phone-mockup {
  display: flex;
  justify-content: center;
  align-items: center;
  perspective: 800px;
}
.phone-frame {
  width: 260px;
  background: #111119;
  border-radius: 36px;
  border: 1.5px solid rgba(200,169,109,0.25);
  padding: 1.2rem 0.8rem;
  box-shadow:
    0 40px 80px rgba(0,0,0,0.6),
    0 0 0 1px rgba(255,255,255,0.03),
    inset 0 1px 0 rgba(255,255,255,0.05);
  transform: rotateY(-8deg) rotateX(4deg);
  transition: transform 0.5s ease;
  animation: phoneFloat 6s ease-in-out infinite;
}
@keyframes phoneFloat {
  0%,100% { transform: rotateY(-8deg) rotateX(4deg) translateY(0); }
  50%      { transform: rotateY(-8deg) rotateX(4deg) translateY(-12px); }
}
.phone-screen {
  background: #07070d;
  border-radius: 24px;
  padding: 1rem 0.8rem;
  min-height: 420px;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  overflow: hidden;
}
.phone-header {
  text-align: center;
  padding-bottom: 0.6rem;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.phone-header-name {
  font-family: 'Playfair Display', serif;
  font-size: 0.85rem;
  color: var(--text);
  font-style: italic;
}
.phone-header-sub {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.45rem;
  letter-spacing: 0.2em;
  color: var(--gold);
  text-transform: uppercase;
}
.phone-msg {
  font-family: 'EB Garamond', serif;
  font-size: 0.75rem;
  line-height: 1.5;
  padding: 0.5rem 0.6rem;
  border-radius: 4px;
  max-width: 85%;
}
.phone-msg.user {
  background: rgba(200,169,109,0.1);
  border: 1px solid rgba(200,169,109,0.15);
  align-self: flex-end;
  color: var(--text);
}
.phone-msg.soul {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  font-style: italic;
  color: rgba(237,231,217,0.8);
}
.phone-msgs { display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
.typing-indicator {
  display: flex; gap: 3px; padding: 0.5rem 0.6rem;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 4px; width: fit-content;
}
.typing-indicator span {
  width: 4px; height: 4px; border-radius: 50%;
  background: var(--gold); opacity: 0.4;
  animation: td 1.4s infinite;
}
.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
@keyframes td {
  0%,60%,100% { transform: translateY(0); opacity: 0.3; }
  30% { transform: translateY(-3px); opacity: 1; }
}

/* ══════════════ FEATURES ══════════════ */
#features {
  max-width: 1100px;
  margin: 0 auto;
  text-align: center;
}
.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.5rem;
  margin-top: 3.5rem;
}
.feature-card {
  background: rgba(255,255,255,0.02);
  border: 1px solid var(--border);
  padding: 2.2rem 1.8rem;
  border-radius: 2px;
  text-align: left;
  transition: background 0.3s, border-color 0.3s, transform 0.3s;
  opacity: 0;
  transform: translateY(20px);
}
.feature-card.visible {
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.6s ease, transform 0.6s ease, background 0.3s, border-color 0.3s;
}
.feature-card:hover {
  background: var(--gold-dim);
  border-color: rgba(200,169,109,0.3);
  transform: translateY(-4px);
}
.feature-icon {
  font-size: 1.6rem;
  margin-bottom: 1rem;
  display: block;
}
.feature-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  font-weight: 400;
  margin-bottom: 0.5rem;
  color: var(--text);
}
.feature-desc {
  font-size: 0.88rem;
  color: var(--text-dim);
  line-height: 1.6;
}

/* ══════════════ TESTIMONIALS ══════════════ */
#testimonials {
  background: rgba(200,169,109,0.025);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.testimonials-inner {
  max-width: 1000px;
  margin: 0 auto;
  text-align: center;
}
.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 2rem;
  margin-top: 3.5rem;
}
.testimonial {
  padding: 2rem;
  border: 1px solid rgba(200,169,109,0.1);
  border-radius: 2px;
  background: rgba(255,255,255,0.02);
  text-align: left;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.testimonial.visible { opacity: 1; transform: translateY(0); }
.testimonial-quote {
  font-family: 'Playfair Display', serif;
  font-size: 2.5rem;
  color: var(--gold);
  line-height: 1;
  margin-bottom: 0.8rem;
  opacity: 0.4;
}
.testimonial-text {
  font-family: 'EB Garamond', serif;
  font-style: italic;
  font-size: 1rem;
  color: var(--text-mid);
  line-height: 1.7;
  margin-bottom: 1.2rem;
}
.testimonial-author {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-dim);
}

/* ══════════════ PRICING ══════════════ */
#pricing {
  max-width: 1100px;
  margin: 0 auto;
  text-align: center;
}
.pricing-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1.5rem;
  margin-top: 3.5rem;
  align-items: start;
}
.pricing-card {
  border: 1px solid var(--border);
  border-radius: 2px;
  padding: 2.5rem 1.8rem;
  text-align: left;
  transition: transform 0.3s, border-color 0.3s;
  background: rgba(255,255,255,0.015);
  opacity: 0;
  transform: translateY(20px);
}
.pricing-card.visible {
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.pricing-card:hover { transform: translateY(-6px); }
.pricing-card.featured {
  border-color: var(--gold);
  background: rgba(200,169,109,0.06);
  position: relative;
}
.pricing-badge {
  position: absolute;
  top: -0.7rem; left: 50%; transform: translateX(-50%);
  background: var(--gold);
  color: #07070d;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.52rem;
  font-weight: 400;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  padding: 0.25rem 0.8rem;
  border-radius: 10px;
  white-space: nowrap;
}
.pricing-tier {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.6rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1rem;
}
.pricing-price {
  font-family: 'Playfair Display', serif;
  font-size: 2.8rem;
  font-weight: 300;
  color: var(--text);
  line-height: 1;
}
.pricing-price sup {
  font-size: 1.2rem;
  vertical-align: super;
}
.pricing-period {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  color: var(--text-dim);
  margin-top: 0.3rem;
  margin-bottom: 1.5rem;
  display: block;
}
.pricing-divider {
  height: 1px;
  background: var(--border);
  margin: 1.2rem 0;
}
.pricing-features { list-style: none; }
.pricing-features li {
  font-size: 0.88rem;
  color: var(--text-mid);
  padding: 0.35rem 0;
  display: flex;
  align-items: center;
  gap: 0.6rem;
}
.pricing-features li::before {
  content: '—';
  color: var(--gold);
  font-size: 0.7rem;
  flex-shrink: 0;
}
.pricing-cta {
  display: block;
  margin-top: 2rem;
  text-align: center;
  padding: 0.75rem 1rem;
  border: 1px solid var(--border);
  color: var(--text-mid);
  font-family: 'Montserrat', sans-serif;
  font-size: 0.62rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-decoration: none;
  transition: all 0.3s;
  border-radius: 1px;
  cursor: none;
}
.pricing-cta:hover { background: var(--gold-dim); border-color: var(--gold); color: var(--gold); }
.pricing-card.featured .pricing-cta {
  background: var(--gold);
  border-color: var(--gold);
  color: #07070d;
}
.pricing-card.featured .pricing-cta:hover { background: var(--gold2); }

/* ══════════════ FINAL CTA ══════════════ */
#cta-final {
  text-align: center;
  padding: clamp(5rem, 12vw, 10rem) 2rem;
  background:
    radial-gradient(ellipse 60% 60% at 50% 50%, rgba(200,169,109,0.06) 0%, transparent 70%);
}
.cta-final-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 5vw, 4rem);
  font-weight: 300;
  line-height: 1.2;
  margin-bottom: 1rem;
  max-width: 600px;
  margin-left: auto; margin-right: auto;
}
.cta-final-title em { font-style: italic; color: var(--gold); }
.cta-final-sub {
  font-style: italic;
  font-size: 1.05rem;
  color: var(--text-mid);
  margin-bottom: 2.5rem;
}
.cta-final-form {
  display: flex;
  gap: 0;
  max-width: 440px;
  margin: 0 auto 1rem;
}

/* ══════════════ FOOTER ══════════════ */
footer {
  position: relative; z-index: 1;
  border-top: 1px solid var(--border);
  padding: 2.5rem 3rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1rem;
}
.footer-logo {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  font-weight: 300;
  letter-spacing: 0.2em;
  color: var(--gold);
}
.footer-tagline {
  font-family: 'EB Garamond', serif;
  font-style: italic;
  font-size: 0.85rem;
  color: var(--text-dim);
}
.footer-links {
  display: flex; gap: 2rem; list-style: none;
}
.footer-links a {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.58rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-dim);
  text-decoration: none;
  transition: color 0.2s;
}
.footer-links a:hover { color: var(--gold); }

/* ══════════════ ANIMATIONS ══════════════ */
@keyframes riseIn {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ══════════════ RESPONSIVE ══════════════ */
@media (max-width: 768px) {
  nav { padding: 1rem 1.5rem; }
  .nav-links { display: none; }
  .how-inner { grid-template-columns: 1fr; gap: 3rem; }
  .phone-mockup { order: -1; }
  footer { flex-direction: column; text-align: center; }
  .waitlist-form, .cta-final-form { flex-direction: column; }
  .waitlist-input { border-right: 1px solid var(--border); border-radius: 1px; border-bottom: none; }
  .waitlist-btn { border-radius: 1px; }
  #stats { gap: 2rem; }
}
</style>
</head>
<body>

